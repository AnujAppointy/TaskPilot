# TaskPilot local development environment.
# Copy this file to .env and replace secrets before exposing the server beyond localhost.

TASKPILOT_ENV=development
TASKPILOT_HTTP_ADDR=127.0.0.1:8080
# Use a local SQLite file for development, or a Postgres URL for production.
# Example Postgres URL: postgres://taskpilot:password@localhost:5432/taskpilot?sslmode=disable
TASKPILOT_DB_URL=taskpilot.db
TASKPILOT_TOKEN=dev-token
TASKPILOT_SECRET_KEY=dev-secret-key-change-me-32-characters
TASKPILOT_BASE_URL=http://127.0.0.1:8080
TASKPILOT_ARTIFACT_DIR=artifacts
TASKPILOT_HEARTBEAT_INTERVAL=5m
